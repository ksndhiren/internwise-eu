{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "internwise-eu",
  "main": "./worker/index.ts",
  "compatibility_date": "2026-04-23",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "observability": {
    "enabled": true
  }
}
